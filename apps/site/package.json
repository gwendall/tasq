{
  "name": "@tasq-internal/site",
  "version": "0.0.0-private",
  "private": true,
  "type": "module",
  "description": "Static ledger-free Tasq product and documentation site generated from canonical repository truth.",
  "scripts": {
    "dev": "bun scripts/generate-truth.ts && next dev",
    "generate": "bun scripts/generate-truth.ts",
    "build": "bun scripts/generate-truth.ts --check && next build",
    "start": "npx serve out",
    "test": "bun scripts/generate-truth.ts --check && bun test",
    "test:browser": "bun scripts/generate-truth.ts --check && next build && playwright test --config playwright.config.ts",
    "typecheck": "bun scripts/generate-truth.ts --check && tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/bun": "1.3.14",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3"
  }
}
