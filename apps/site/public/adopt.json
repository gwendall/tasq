{
  "$schema": "/schemas/public-adoption.v1.schema.json",
  "contractVersion": "tasq.public-adoption.v1",
  "product": "Tasq Local",
  "support": "implemented_certified",
  "distribution": {
    "mode": "npm_and_github_release",
    "published": true,
    "version": "0.1.0",
    "tag": "v0.1.0",
    "repository": "https://github.com/gwendall/tasq",
    "githubRelease": "https://github.com/gwendall/tasq/releases/tag/v0.1.0",
    "packages": [
      {
        "name": "@tasq-run/schema",
        "version": "0.1.0"
      },
      {
        "name": "@tasq-run/core",
        "version": "0.1.0"
      },
      {
        "name": "@tasq-run/cli",
        "version": "0.1.0"
      },
      {
        "name": "@tasq-run/mcp",
        "version": "0.1.0"
      },
      {
        "name": "@tasq-run/extension-sdk",
        "version": "0.1.0"
      },
      {
        "name": "@tasq-run/protocol-adapters",
        "version": "0.1.0"
      },
      {
        "name": "@tasq-run/console",
        "version": "0.1.0"
      }
    ],
    "cliTargets": [
      "darwin-arm64",
      "linux-x64-gnu"
    ],
    "integrity": {
      "kind": "npm-provenance-and-github-attestation",
      "sourceCommit": "0f5357ea10e0eb9f86f143a4fc38030624238bd2",
      "releaseManifestPattern": "tasq-v0.1.0-{target}.release.json",
      "checksumPattern": "tasq-v0.1.0-{target}.SHA256SUMS"
    }
  },
  "requirements": [
    {
      "runtime": "node",
      "version": ">=22"
    },
    {
      "runtime": "bun",
      "version": ">=1.3.0"
    },
    {
      "runtime": "npm",
      "version": ">=10"
    }
  ],
  "human": {
    "path": "/docs/getting-started/",
    "primaryAction": "install_release"
  },
  "agent": {
    "acquisition": [
      {
        "id": "package.install",
        "cwd": "{workingDirectory}",
        "argv": [
          "npm",
          "install",
          "--prefix",
          "{installPrefix}",
          "--ignore-scripts",
          "@tasq-run/cli@0.1.0"
        ],
        "mutatesHost": true
      }
    ],
    "executablePathTemplate": "{installPrefix}/node_modules/.bin/tasq",
    "onboardArgvTemplate": [
      "{tasqExecutable}",
      "onboard",
      "--space",
      "{workspaceId}",
      "--actor",
      "{actorLabel}",
      "--capabilities",
      "read,propose,coordinate",
      "--json"
    ],
    "placeholders": [
      "{workingDirectory}",
      "{installPrefix}",
      "{tasqExecutable}",
      "{workspaceId}",
      "{actorLabel}"
    ]
  },
  "invariants": [
    "execute_argv_without_shell_reconstruction",
    "verify_registry_version_and_release_provenance",
    "persist_one_executable_identity_for_the_session",
    "read_before_mutation",
    "actor_labels_are_attribution_not_authentication",
    "same_workspace_requires_the_same_store",
    "device_time_is_not_authority",
    "runtime_success_does_not_complete_a_commitment",
    "uninstall_never_removes_user_data"
  ]
}
