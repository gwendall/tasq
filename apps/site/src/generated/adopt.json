{
  "$schema": "/schemas/public-adoption.v1.schema.json",
  "contractVersion": "tasq.public-adoption.v1",
  "product": "Tasq Local",
  "support": "implemented_candidate_not_published",
  "distribution": {
    "mode": "source_build",
    "published": false,
    "repository": "https://github.com/gwendall/tasq",
    "repositoryAccess": "authorized_private_prelaunch",
    "preconditions": [
      "authorized_repository_access"
    ],
    "sourceRef": "main",
    "sourceRefMutable": true,
    "integrity": {
      "kind": "repository-contract-digests",
      "sourceContracts": [
        {
          "path": "PRODUCT_SURFACE_MATRIX.json",
          "sha256": "360c4db8850865438324465e1e34c6f37335e80f468903d2faaafa3adbd915f6"
        },
        {
          "path": "BACKLOG.json",
          "sha256": "7e6a2df02994ee84eabac45ec5247b3a600bf1add0962ab3bb9062413c3eb282"
        },
        {
          "path": "PUBLIC_RELEASE_POLICY.json",
          "sha256": "a6b90b4900f56a59713a9f1a4e58c64b38aaa03ccf2a9c308aa295fed7d0d628"
        }
      ]
    }
  },
  "requirements": [
    {
      "runtime": "node",
      "version": ">=22"
    },
    {
      "runtime": "bun",
      "version": ">=1.3.0"
    },
    {
      "runtime": "pnpm",
      "version": "10.29.3"
    }
  ],
  "human": {
    "path": "/docs/getting-started/",
    "primaryAction": "request_access_then_build"
  },
  "agent": {
    "acquisition": [
      {
        "id": "source.clone",
        "cwd": "{parentDirectory}",
        "argv": [
          "git",
          "clone",
          "https://github.com/gwendall/tasq",
          "{checkoutPath}"
        ],
        "mutatesHost": true
      },
      {
        "id": "dependencies.install",
        "cwd": "{checkoutPath}",
        "argv": [
          "pnpm",
          "install",
          "--frozen-lockfile"
        ],
        "mutatesHost": true
      },
      {
        "id": "source.verify",
        "cwd": "{checkoutPath}",
        "argv": [
          "pnpm",
          "typecheck"
        ],
        "mutatesHost": false
      },
      {
        "id": "cli.build",
        "cwd": "{checkoutPath}",
        "argv": [
          "pnpm",
          "build:cli"
        ],
        "mutatesHost": true
      }
    ],
    "executableRelativePath": "dist/cli/index.js",
    "onboardArgvTemplate": [
      "{tasqExecutable}",
      "onboard",
      "--space",
      "{workspaceId}",
      "--actor",
      "{actorLabel}",
      "--capabilities",
      "read,propose,coordinate",
      "--json"
    ],
    "placeholders": [
      "{parentDirectory}",
      "{checkoutPath}",
      "{tasqExecutable}",
      "{workspaceId}",
      "{actorLabel}"
    ]
  },
  "invariants": [
    "execute_argv_without_shell_reconstruction",
    "persist_one_executable_identity_for_the_session",
    "read_before_mutation",
    "actor_labels_are_attribution_not_authentication",
    "same_workspace_requires_the_same_store",
    "device_time_is_not_authority",
    "runtime_success_does_not_complete_a_commitment",
    "private_prelaunch_repository_requires_authorized_access",
    "unpublished_source_ref_is_mutable_and_not_a_release_attestation"
  ]
}
