{
  "name": "tasq-monorepo",
  "version": "0.0.0-private",
  "private": true,
  "description": "Universal local-first commitment coordination for humans, agents, and runtimes.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22"
  },
  "scripts": {
    "agent:preflight": "bun scripts/agent-preflight.ts",
    "verify:quick": "bun scripts/verify-handoff.ts --quick",
    "verify:handoff": "bun scripts/verify-handoff.ts",
    "docs:check": "bun test packages/tasq-evals/documentation-contract.test.ts",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm --workspace-concurrency=1 -r --if-present test",
    "build:site": "pnpm --filter @tasq-internal/site build",
    "test:site:browser": "pnpm --filter @tasq-internal/site test:browser",
    "build:cli": "bun packages/tasq-cli/scripts/build.ts --outdir dist/cli",
    "build:packages": "bun scripts/release/build-public-packages.ts",
    "verify:export": "bun test packages/tasq-cli/test/public-packages.test.ts packages/tasq-cli/test/extension-boundary.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
