  "scenarios": [
    {
      "id": "protected_resource_discovery_no_data",
      "principles": ["discoverable_authentication", "no_unauthenticated_workspace_data"],
      "surfaces": ["rest", "remote_mcp"],
      "requiredOutcome": "public metadata and typed 401 reveal no workspace state"
    },
    {
      "id": "issuer_subject_collision",
      "principles": ["issuer_subject_identity", "no_email_identity"],
      "surfaces": ["rest"],
      "requiredOutcome": "same subject from two issuers maps to distinct bindings"
    },
    {
      "id": "cross_workspace_read_probe",
      "principles": ["store_isolation", "live_authorization"],
      "surfaces": ["rest", "remote_mcp", "hosted_web_bff"],
      "requiredOutcome": "deny before the foreign workspace store is read"
    },
    {
      "id": "revoked_grant_unexpired_token",
      "principles": ["token_scope_is_upper_bound", "immediate_revocation"],
      "surfaces": ["rest", "remote_mcp"],
      "requiredOutcome": "next request denies from the live grant state"
    },
    {
      "id": "disabled_binding_unexpired_token",
      "principles": ["subject_binding_is_live", "immediate_revocation"],
      "surfaces": ["rest", "hosted_web_bff"],
      "requiredOutcome": "next request denies without rewriting history"
    },
    {
      "id": "delegated_agent_intersection",
      "principles": ["subject_actor_separation", "least_privilege_delegation"],
      "surfaces": ["rest", "remote_mcp"],
      "requiredOutcome": "authority is the intersection of subject actor token and delegation"
    },
    {
      "id": "surface_switch_no_widening",
      "principles": ["one_guard", "one_ledger"],
      "surfaces": ["rest", "remote_mcp", "hosted_web_bff"],
      "requiredOutcome": "the same identity action and resource produce the same decision"
    },
    {
      "id": "privileged_token_replay",
      "principles": ["sender_constraint", "replay_detection"],
      "surfaces": ["rest", "remote_mcp"],
      "requiredOutcome": "stolen or repeated sender proof cannot administer approve or dispatch"
    },
    {
      "id": "unknown_key_rotation",
      "principles": ["pinned_issuer", "fail_closed_rotation"],
      "surfaces": ["rest", "hosted_web_bff"],
      "requiredOutcome": "one bounded refresh succeeds only for a key from the pinned issuer"
    },
    {
      "id": "metadata_outage",
      "principles": ["fail_closed_rotation", "bounded_cache"],
      "surfaces": ["rest", "remote_mcp"],
      "requiredOutcome": "unknown credentials deny and never downgrade to actor text"
    },
    {
      "id": "concurrent_revocation_and_mutation",
      "principles": ["atomic_authority", "optimistic_concurrency"],
      "surfaces": ["rest"],
      "requiredOutcome": "mutation and authority preconditions commit together or deny retryably"
    },
    {
      "id": "effect_separation_of_duty",
      "principles": ["authorization_is_not_approval", "exact_effect_gate"],
      "surfaces": ["rest", "remote_mcp"],
      "requiredOutcome": "workspace admin alone cannot approve or dispatch an effect"
    },
    {
      "id": "headless_device_authorization",
      "principles": ["honest_bootstrap", "human_consent"],
      "surfaces": ["rest", "remote_mcp"],
      "requiredOutcome": "agent receives typed device instructions and no authority before approval"
    },
    {
      "id": "workload_attestation_rotation",
      "principles": ["workload_identity_adapter", "short_lived_credentials"],
      "surfaces": ["rest", "remote_mcp"],
      "requiredOutcome": "rotated workload identity retains subject continuity without stored private keys"
    },
    {
      "id": "replica_revocation",
      "principles": ["authority_required_sync", "no_stale_reactivation"],
      "surfaces": ["rest"],
      "requiredOutcome": "revoked replica cannot push enroll or self-reactivate"
    },
    {
      "id": "injected_clock_matrix",
      "principles": ["injected_authority_time", "time_is_not_order"],
      "surfaces": ["rest", "remote_mcp", "hosted_web_bff"],
      "requiredOutcome": "freeze advance and rewind affect only explicit validity boundaries"
    },
    {
      "id": "lost_response_retry",
      "principles": ["durable_idempotency", "decision_audit"],
      "surfaces": ["rest", "remote_mcp"],
      "requiredOutcome": "exact retry reuses one accepted result and one authority decision identity"
    }
