{
  "name": "@tasq-run/cli",
  "version": "0.1.0",
  "description": "Tasq Local CLI, autonomous onboarding entrypoint and Bun executable.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "tasq": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "bun run ./scripts/build.ts",
    "test": "bun run ./scripts/test.ts",
    "prepublishOnly": "node -e \"throw new Error('Use the protected release workflow')\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tasq-run/console": "workspace:*",
    "@tasq-run/mcp": "workspace:*",
    "@tasq-run/schema": "workspace:*",
    "@tasq-internal/local-service": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gwendall/tasq.git",
    "directory": "packages/tasq-cli"
  },
  "bugs": {
    "url": "https://github.com/gwendall/tasq/issues"
  },
  "homepage": "https://tasq.run",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
