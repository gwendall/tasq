{
  "name": "@tasq/schema",
  "version": "0.1.0",
  "description": "Portable Tasq schemas, TypeScript types, identifiers, clock contracts and Drizzle table definitions.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tables": "./src/tables.ts",
    "./types": "./src/types.ts",
    "./extensions": "./src/extensions.ts",
    "./discovery": "./src/discovery.ts",
    "./effects": "./src/effects.ts",
    "./replication": "./src/replication.ts",
    "./bootstrap": "./src/bootstrap.ts",
    "./resources": "./src/resources.ts",
    "./context": "./src/context.ts",
    "./summaries": "./src/summaries.ts",
    "./clock": "./src/clock.ts",
    "./ids": "./src/ids.ts",
    "./console": "./src/console.ts"
  },
  "scripts": {
    "test": "bun test",
    "prepublishOnly": "node -e \"throw new Error('Use the protected release workflow')\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gwendall/tasq.git",
    "directory": "packages/tasq-schema"
  },
  "bugs": {
    "url": "https://github.com/gwendall/tasq/issues"
  },
  "homepage": "https://github.com/gwendall/tasq#readme",
